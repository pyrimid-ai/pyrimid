# ═══════════════════════════════════════════════════════════
#                     Pyrimid App — Environment
# ═══════════════════════════════════════════════════════════

# Base URL (set by Vercel automatically, or override for local dev)
NEXT_PUBLIC_BASE_URL=https://pyrimid.xyz

# Subgraph endpoint (The Graph Studio)
PYRIMID_SUBGRAPH_URL=https://api.studio.thegraph.com/query/YOUR_ID/pyrimid-base/version/latest

# External catalog sources
# Bazaar (x402 CDP facilitator — this is the real production endpoint)
# BAZAAR_CATALOG_URL=https://api.cdp.coinbase.com/platform/v2/x402/discovery/resources
#
# MCPize, MCP Hive, Apify — no stable public REST APIs yet.
# Set these when/if they ship public catalog endpoints.
# MCPIZE_CATALOG_URL=
# MCPHIVE_CATALOG_URL=
# APIFY_CATALOG_URL=
