{
  "name": "@pyrimid/sdk",
  "version": "0.1.0",
  "description": "Onchain monetization infrastructure for agent-to-agent commerce on Base",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "pyrimid",
    "agent",
    "a2a",
    "mcp",
    "x402",
    "affiliate",
    "base",
    "usdc",
    "erc-8004",
    "onchain"
  ],
  "author": "Pyrimid Protocol",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyrimid/sdk"
  },
  "homepage": "https://pyrimid.xyz/docs",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "@x402/fetch": ">=0.0.1",
    "zod": ">=3.20.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": { "optional": true },
    "@x402/fetch": { "optional": true },
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@x402/fetch": "^2.6.0",
    "typescript": "^5.4.0",
    "zod": "^3.22.0"
  }
}
